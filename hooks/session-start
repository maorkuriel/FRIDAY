#!/usr/bin/env bash
# SessionStart hook for F.R.I.D.A.Y plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

gateway_content=$(cat "${PLUGIN_ROOT}/skills/friday/SKILL.md" 2>&1 || echo "Error reading friday gateway skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

gateway_escaped=$(escape_for_json "$gateway_content")
session_context="<FRIDAY>\nYou have F.R.I.D.A.Y installed.\n\n**Below is the full content of your 'friday' gateway skill. For all other PM skills, use the 'Skill' tool:**\n\n${gateway_escaped}\n</FRIDAY>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
